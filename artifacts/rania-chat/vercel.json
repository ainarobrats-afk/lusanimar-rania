{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/chat",     "destination": "https://rania-parser.lusanimar.workers.dev/api/chat" },
    { "source": "/api/health",   "destination": "https://rania-parser.lusanimar.workers.dev/api/health" },
    { "source": "/api/ads/:path*", "destination": "https://rania-parser.lusanimar.workers.dev/api/ads/:path*" },
    { "source": "/rania/chat",   "destination": "https://rania-parser.lusanimar.workers.dev/api/chat" },
    { "source": "/rania/flights","destination": "https://rania-hunter.lusanimar.workers.dev/api/search" },
    { "source": "/rania/status/:bookingId", "destination": "https://rania-admin.lusanimar.workers.dev/api/admin/booking/:bookingId" },
    { "source": "/rania/currency",          "destination": "https://rania-parser.lusanimar.workers.dev/api/currency" },
    { "source": "/rania/weather",           "destination": "https://rania-parser.lusanimar.workers.dev/api/weather" },
    { "source": "/rania/visa",              "destination": "https://rania-parser.lusanimar.workers.dev/api/visa" },
    { "source": "/rania/price-track",       "destination": "https://rania-parser.lusanimar.workers.dev/api/price-track" },
    { "source": "/rania/price-track/:id",   "destination": "https://rania-parser.lusanimar.workers.dev/api/price-track/:id" },
    { "source": "/rania/price-alerts/:path*","destination": "https://rania-parser.lusanimar.workers.dev/api/price-alerts/:path*" },
    { "source": "/rania/group-booking",     "destination": "https://rania-cashier.lusanimar.workers.dev/api/group-booking" },
    { "source": "/rania/booking/:id",       "destination": "https://rania-admin.lusanimar.workers.dev/api/admin/booking/:id" },
    { "source": "/rania/booking",           "destination": "https://rania-cashier.lusanimar.workers.dev/api/booking" },
    { "source": "/rania/register-user",     "destination": "https://rania-parser.lusanimar.workers.dev/api/register-user" },
    { "source": "/rania/bookings",           "destination": "https://rania-admin.lusanimar.workers.dev/api/admin/bookings" },
    { "source": "/rania/bookings/:id/resend","destination": "https://rania-admin.lusanimar.workers.dev/api/admin/bookings/:id/resend" },
    { "source": "/rania/bookings/:id",       "destination": "https://rania-admin.lusanimar.workers.dev/api/admin/bookings/:id" },
    { "source": "/rania/admin/:path*",       "destination": "https://rania-admin.lusanimar.workers.dev/api/admin/:path*" },
    { "source": "/rania/passport-scan",      "destination": "https://rania-validator.lusanimar.workers.dev/api/validate" },
    { "source": "/api/rania/:path*",         "destination": "https://rania-parser.lusanimar.workers.dev/api/:path*" },
    { "source": "/api/search",   "destination": "https://rania-hunter.lusanimar.workers.dev/api/search" },
    { "source": "/api/validate", "destination": "https://rania-validator.lusanimar.workers.dev/api/validate" },
    { "source": "/api/checkout", "destination": "https://rania-cashier.lusanimar.workers.dev/api/checkout" },
    { "source": "/api/webhook/:path*", "destination": "https://rania-webhook.lusanimar.workers.dev/api/webhook/:path*" },
    { "source": "/api/admin/:path*",   "destination": "https://rania-admin.lusanimar.workers.dev/api/admin/:path*" },
    { "source": "/api/book",     "destination": "https://rania-pilot.lusanimar.workers.dev/api/book" },
    { "source": "/(.*)",         "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, x-request-id, x-session-id, x-admin-token" }
      ]
    }
  ]
}
